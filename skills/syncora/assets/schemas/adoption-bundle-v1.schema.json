{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syncora.dev/schemas/adoption-bundle-v1.schema.json",
  "title": "Syncora legacy adoption bundle v1",
  "description": "A portable, content-addressed descriptor binding every reviewed input to one foreground legacy adoption run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "migrationId",
    "manifest",
    "stagedContent",
    "fixtures"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "syncora-adoption-bundle-v1" },
    "migrationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "manifest": { "$ref": "#/$defs/fileBinding" },
    "fixtures": { "$ref": "#/$defs/fileBinding" },
    "stagedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "targetCount", "totalBytes", "targets"],
      "properties": {
        "root": { "$ref": "#/$defs/portableRelativePath" },
        "targetCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "totalBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 67108864
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/targetBinding" }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "portableRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*[. ](?:/|$))(?!.*(?:^|/)(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.|/|$))(?!.*[\\\\<>:\"|?*\\u0000-\\u001F\\u007F-\\u009F\\u061C\\u200E\\u200F\\u2028-\\u202E\\u2066-\\u2069])[^/]{1,240}(?:/[^/]{1,240})*$"
    },
    "markdownRelativePath": {
      "allOf": [
        { "$ref": "#/$defs/portableRelativePath" },
        { "type": "string", "pattern": "\\.md$" }
      ]
    },
    "fileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/portableRelativePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "targetBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byteLength"],
      "properties": {
        "path": { "$ref": "#/$defs/markdownRelativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "byteLength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 262144
        }
      }
    }
  }
}
